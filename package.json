{
  "name": "mini-editor",
  "version": "0.1.0",
  "description": "A sub-5kb, zero-dependency WYSIWYG editor with built-in XSS protection",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js",
      "require": "./dist/sanitize.cjs"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.js",
      "require": "./dist/policy.cjs"
    },
    "./toolbar": {
      "types": "./dist/toolbar.d.ts",
      "import": "./dist/toolbar.js",
      "require": "./dist/toolbar.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node esbuild.config.js && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "npx playwright test",
    "size-check": "node scripts/size-check.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "contenteditable",
    "xss",
    "sanitizer",
    "security",
    "lightweight",
    "zero-dependency"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erikleon/niewielki-editor"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "happy-dom": "^17.0.0",
    "@playwright/test": "^1.50.0"
  }
}
